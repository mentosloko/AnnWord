# Frontend Supabase config
# Copy this file to .env.local and fill the values from Supabase project settings.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Optional: comma-separated emails that should receive admin role in the app profile
VITE_ADMIN_EMAILS=

# Optional: Gemini API key if AI features are enabled in the app
GEMINI_API_KEY=

# Server-only config for custom Yandex OAuth flow via server.ts
# Do not expose these values in frontend code.
SUPABASE_SERVICE_ROLE_KEY=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
APP_URL=http://localhost:3000
