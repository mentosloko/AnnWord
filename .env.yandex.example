# AnnWord Yandex Cloud runtime template
# Copy to .env.local only for local checks. Do not commit real values.

NODE_ENV=production
PORT=8080

# Public URLs
APP_URL=https://app.example.ru
API_URL=https://api.example.ru
CORS_ORIGIN=https://app.example.ru

# PostgreSQL / Yandex Managed PostgreSQL
DATABASE_URL=postgresql://annword_app:CHANGE_ME@rc1x-example.mdb.yandexcloud.net:6432/annword?sslmode=require
PGHOST=rc1x-example.mdb.yandexcloud.net
PGPORT=6432
PGDATABASE=annword
PGUSER=annword_app
PGPASSWORD=CHANGE_ME
PGPOOL_MAX=5

# Auth/session secrets
SESSION_SECRET=CHANGE_ME
JWT_SECRET=CHANGE_ME
COOKIE_SECRET=CHANGE_ME

# Prodamus
PRODAMUS_SECRET=CHANGE_ME

# Yandex OAuth
YANDEX_CLIENT_ID=CHANGE_ME
YANDEX_CLIENT_SECRET=CHANGE_ME

# Yandex Object Storage / S3-compatible API
S3_ENDPOINT=https://storage.yandexcloud.net
S3_FRONTEND_BUCKET=annword-frontend-prod
S3_ASSETS_BUCKET=annword-assets-prod
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME

# Yandex Cloud deploy resource IDs
YC_CLOUD_ID=CHANGE_ME
YC_FOLDER_ID=CHANGE_ME
YC_SERVICE_ACCOUNT_ID=CHANGE_ME
YC_REGISTRY_ID=CHANGE_ME
YC_SERVERLESS_CONTAINER_ID=CHANGE_ME
