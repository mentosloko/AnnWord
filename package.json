    "assets:audit": "tsx scripts/audit-assets.ts",
    "daily-quest:smoke": "tsx scripts/daily-quest-smoke.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:simulation": "tsx scripts/simulate-1000-users.ts",
    "check:unit": "vitest run",
    "dictionary:smoke": "tsx scripts/dictionary-engine-smoke.ts",
    "navigation:smoke": "tsx scripts/navigation-smoke.ts",
    "route:smoke": "tsx scripts/route-contract-smoke.ts",
    "economy:smoke": "tsx scripts/economy-smoke.ts",
    "pet:smoke": "tsx scripts/pet-engine-smoke.ts",
    "screens:smoke": "tsx scripts/screen-components-smoke.ts",
    "hooks:smoke": "tsx scripts/hooks-smoke.ts",
    "appv2:smoke": "tsx scripts/appv2-architecture-smoke.ts",
    "premium-dictionaries:validate": "tsx scripts/validatePremiumDictionaries.ts",
    "check:smoke": "npm run dictionary:smoke && npm run navigation:smoke && npm run route:smoke && npm run economy:smoke && npm run pet:smoke && npm run screens:smoke && npm run hooks:smoke && npm run appv2:smoke",
    "check": "npm run lint && npm run premium-dictionaries:validate && npm run check:unit && npm run check:smoke && npm run api:check",
    "build": "python3 -m pip install --break-system-packages --disable-pip-version-check --quiet reportlab==4.4.3 matplotlib==3.10.3 && python3 scripts/inspect_legal_sources.py && python3 scripts/generate_legal_pdfs.py && vite build",
    "build:verified": "npm run check && npm run build",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.33.0",
    "@supabase/supabase-js": "^2.100.1",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "motion": "^12.38.0",
    "pg": "^8.16.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
